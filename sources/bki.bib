@article{dhir2025social,
  author    = {Dhir, Swati and Vallabh, Priyanka},
  title     = {Do social relationships at work enhance creativity and innovative behavior? {Role} of psychological safety},
  journal   = {Acta Psychologica},
  volume    = {253},
  pages     = {104751},
  year      = {2025},
  publisher = {Elsevier BV},
  doi       = {10.1016/j.actpsy.2025.104751},
  pmid      = {39874863},
  note      = {Quantitative, n=515 employees + 105 team leads, IT/ITeS sector, 3-month longitudinal. Psychological safety fully mediates workplace social belonging → creativity and innovative behavior. BKI Propositions 1 (Cognitive Scaffolding) + 2 (Relational Validation). VERIFIED_PEER_REVIEWED}
}

@article{ozlu2026social,
  author    = {Ozlu, Canberk and Sezer, Umut and Durdubas, Deniz and Koruc, Ziya},
  title     = {From social identity to team performance: {Linking} transactive memory systems and teamwork},
  journal   = {Psychology of Sport and Exercise},
  volume    = {82},
  pages     = {103007},
  year      = {2026},
  publisher = {Elsevier BV},
  doi       = {10.1016/j.psychsport.2025.103007},
  pmid      = {41115646},
  note      = {3-wave longitudinal, n=167 athletes across 15 teams. Shared team identity → transactive memory system (TMS) formation → teamwork behaviors → team performance. Belonging-based identity structures scaffold distributed cognition. BKI Proposition 2 (Relational Validation) + Proposition 1 (Cognitive Scaffolding). VERIFIED_PEER_REVIEWED}
}

@article{yuan2026bnst,
  author    = {Yuan, Hongxia and Zhong, Yongmei and Zhang, Xuehan},
  title     = {Separate {BNST} Microcircuits Targeted by Direct Versus Amygdala-Relayed Prefrontal Inputs Mediate Dissociable Phenotypes After Isolation},
  journal   = {Cells},
  volume    = {15},
  number    = {2},
  pages     = {116},
  year      = {2026},
  publisher = {MDPI AG},
  doi       = {10.3390/cells15020116},
  pmid      = {41597191},
  note      = {Mechanistic animal neuroscience (Fudan University). Chronic social isolation activates PFC→BLA→BNST pathway driving anxiety, depression, and social deficits; chemogenetic BLA inhibition ameliorates all three phenotypes. Neural substrate of BKI Proposition 1: social exclusion activates amygdala circuits suppressing prefrontal regulatory function. VERIFIED_PEER_REVIEWED}
}

