{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/corpus-pack/v0.1/source_manifest.schema.json",
  "title": "Corpus Pack Source Manifest v0.1",
  "type": "object",
  "required": [
    "source_id",
    "title",
    "author_or_organization",
    "source_type",
    "publication_date",
    "version_or_edition",
    "effective_date",
    "retrieval_date",
    "canonical_url_or_locator",
    "license_or_rights_posture",
    "public_domain_status",
    "content_hash",
    "source_authority_roles",
    "quality_flags",
    "privacy_or_sensitivity",
    "citation_format"
  ],
  "properties": {
    "source_id": {"type": "string"},
    "title": {"type": "string"},
    "author_or_organization": {"type": "string"},
    "source_type": {"type": "string", "enum": ["book", "paper", "documentation", "report", "historical_document", "dataset", "web_page", "standard", "other"]},
    "publication_date": {"type": "string"},
    "version_or_edition": {"type": "string"},
    "effective_date": {"type": "string"},
    "retrieval_date": {"type": "string", "format": "date"},
    "canonical_url_or_locator": {"type": "string"},
    "license_or_rights_posture": {"type": "string", "enum": ["public_domain", "cc_by", "cc_by_sa", "cc_by_nc", "cc_by_nd", "cc_zero", "fair_use", "restricted", "other"]},
    "public_domain_status": {"type": "boolean"},
    "content_hash": {"type": "string"},
    "local_or_object_storage_locator": {"type": ["string", "null"]},
    "source_authority_roles": {"type": "array", "items": {"type": "string", "enum": ["primary", "secondary", "tertiary", "corroborating", "contradicting", "superseded", "corrected"]}},
    "known_corrections_or_retractions": {"type": "array", "items": {"type": "object"}},
    "OCR_or_extraction_method": {"type": ["string", "null"]},
    "quality_flags": {"type": "array", "items": {"type": "string", "enum": ["high_quality", "medium_quality", "low_quality", "ocr_defects", "incomplete", "redacted", "excerpt_only"]}},
    "included_segments": {"type": "array", "items": {"type": "string"}},
    "excluded_segments_and_reason": {"type": "array", "items": {"type": "object", "properties": {"segment": {"type": "string"}, "reason": {"type": "string"}}}},
    "privacy_or_sensitivity": {"type": "string", "enum": ["public_safe", "sensitive", "restricted"]},
    "citation_format": {"type": "string"}
  }
}
