{
  "name": "hummbl-bibliography",
  "version": "1.0.0",
  "description": "A curated bibliography for HUMMBL project",
  "private": true,
  "scripts": {
    "test": "node scripts/check-root-package.mjs && npm --prefix toolkit test",
    "validate": "npm --prefix toolkit run validate",
    "validate:ci": "npm --prefix toolkit run validate:ci",
    "check-dups": "npm --prefix toolkit run check-dups",
    "check-required-fields": "npm --prefix toolkit run check-required-fields",
    "stats": "npm --prefix toolkit run stats",
    "stats:json": "npm --prefix toolkit run stats:json",
    "lint": "npm --prefix toolkit run lint --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hummbl-dev/hummbl-bibliography.git"
  },
  "keywords": [
    "bibliography",
    "hummbl",
    "references"
  ],
  "author": "HUMMBL Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hummbl-dev/hummbl-bibliography/issues"
  },
  "homepage": "https://github.com/hummbl-dev/hummbl-bibliography#readme"
}
