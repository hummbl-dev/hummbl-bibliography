{
  "name": "hummbl-bibliography-toolkit",
  "version": "1.0.0",
  "description": "Validation and management toolkit for HUMMBL Bibliography",
  "type": "module",
  "main": "src/validate.js",
  "exports": "./src/validate.js",
  "scripts": {
    "prepare": "husky install",
    "validate": "node src/validate.js ../bibliography",
    "validate:staged": "node src/validate.js --staged",
    "validate:ci": "node src/validate.js ../bibliography --ci",
    "check-dups": "node src/check-duplicates.js ../bibliography",
    "check-duplicates": "node src/check-duplicates.js --fail-on-duplicates ../bibliography",
    "fix-dups": "node src/fix-duplicates.js ../bibliography",
    "find-dois": "node src/find-missing-dois.js ../bibliography",
    "check-required-fields": "node src/check-required-fields.js ../bibliography",
    "stats": "node src/stats.js ../bibliography",
    "stats:json": "node src/stats.js ../bibliography --json",
    "keywords": "node src/extract-keywords.js ../bibliography",
    "query": "node src/query.js ../bibliography",
    "merge": "node src/merge-entries.js",
    "grounding:build": "node src/build-scientific-grounding.js",
    "grounding:check": "node src/build-scientific-grounding.js --check",
    "generate-unified": "node src/generate-unified-bibliography.js",
    "sync-llms": "npm run generate-llms",
    "build:all": "node src/generate-unified-bibliography.js && node src/generate-llms-txt.js && node src/build-scientific-grounding.js",
    "merge-dois": "node src/merge-enriched-dois.js && npm run build:all",
    "validate:bibliography-schema": "node src/validate-bibliography-schema-registry.js ../sources/bibliography/bibliography-schema-registry-v0.1.json",
    "validate:bibliography-schema:fixtures": "node src/validate-bibliography-schema-registry.js --self-test ../fixtures/bibliography-schema-registry-v0.1.fixtures.json",
    "test": "npm run validate && npm run validate:bibliography-schema && npm run validate:bibliography-schema:fixtures && npm run check-duplicates && npm run check-required-fields && npm run validate:memory-palace && npm run grounding:check && npm run test:unit",
    "validate:memory-palace": "node scripts/check-memory-palace-aliases.js",
    "test:memory-palace": "node --test scripts/check-memory-palace-aliases.test.js",
    "test:unit": "node --test scripts/find-missing-dois.test.js scripts/fix-duplicates-args.test.js scripts/check-memory-palace-aliases.test.js scripts/maintenance-cli.test.js scripts/citation-graph.test.js scripts/citation-graph-url-policy.test.js scripts/fail-closed-parsers.test.js scripts/watch.test.js scripts/generate-docs.test.js scripts/parse-audit-report.test.js scripts/security-audit-workflow.test.js scripts/validate-doi-unavailable.test.js scripts/harness-preflight.test.js scripts/gitleaks-citation-key-adversarial.test.js",
    "precommit": "npm run validate && npm run validate:bibliography-schema && npm run validate:bibliography-schema:fixtures && npm run validate:memory-palace && npm run test:unit",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "generate-docs": "node scripts/generate-docs.js",
    "watch": "node src/watch.js ../bibliography",
    "citation-graph": "node src/citation-graph.js ../bibliography"
  },
  "keywords": [
    "bibliography",
    "bibtex",
    "hummbl",
    "cognitive-framework",
    "validation"
  ],
  "author": "HUMMBL Team",
  "license": "MIT",
  "dependencies": {
    "@citation-js/core": "^0.8.2",
    "@citation-js/plugin-bibtex": "^0.8.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.18.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.19",
    "postcss-functions": "^4.0.2",
    "postcss-js": "^5.1.0",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2"
  },
  "lint-staged": {
    "../bibliography/*.bib": [
      "npm run validate:ci --",
      "npm run check-dups",
      "npm run generate-llms"
    ],
    "src/**/*.js": [
      "node --check"
    ],
    "*.json": [
      "node -e \"JSON.parse(require('fs').readFileSync(process.argv[1],'utf8'))\""
    ],
    "../.github/workflows/*.yml": [
      "node -e \"const s=require('fs').readFileSync(process.argv[1],'utf8');if(!s.includes('on:'))process.exit(1)\""
    ]
  }
}
