@book{Popper1959LogicDiscovery,
  title     = {The Logic of Scientific Discovery},
  author    = {Popper, Karl R.},
  year      = {1959},
  publisher = {Routledge},
  address   = {London},
  doi-unavailable = {Original 1959 English translation; Routledge Classics edition has no DOI assigned},
  isbn      = {9780415278447},
  abstract  = {Popper's foundational work on the philosophy of science introduces falsification as the demarcation criterion between science and non-science. Rather than verifying theories through induction, Popper argues that scientific theories must be falsifiable -- they must make predictions that could, in principle, be proven false. The stronger a theory's falsifiability, the more informative it is. This inverts the traditional verificationist epistemology: a theory is not scientific because it can be confirmed, but because it can be refuted. Popper addresses the problem of induction by showing that science does not rely on it -- instead, science progresses through bold conjectures and rigorous attempts at refutation. For HUMMBL, Popper's falsificationism grounds the IN (Inversion) transformation: the systematic search for failure modes, counterexamples, and disconfirming evidence is the operationalization of falsification. A reasoning system that cannot be falsified is not scientific; a mental model that cannot be inverted is not robust. The Logic of Scientific Discovery provides the epistemological foundation for treating inversion as a first-class reasoning operation rather than an afterthought.},
  keywords  = {falsification, philosophy of science, demarcation, epistemology, HUMMBL:IN, HUMMBL:P, HUMMBL:RE},
}

@book{Watzlawick1974Change,
  title     = {Change: Principles of Problem Formation and Problem Resolution},
  author    = {Watzlawick, Paul and Weakland, John H. and Fisch, Richard},
  year      = {1974},
  publisher = {W. W. Norton & Company},
  address   = {New York},
  doi-unavailable = {Norton trade book; no DOI assigned},
  isbn      = {9780393011043},
  abstract  = {Watzlawick, Weakland, and Fisch introduce the distinction between first-order change (more of the same within an existing system) and second-order change (a fundamental shift in the system's rules). Drawing on Bateson's double bind theory and the Mental Research Institute's brief therapy tradition, they show how attempted solutions often become the problem: repeating a failed strategy harder, simplifying a complex situation prematurely, or insisting on utopian perfection. Paradoxical interventions -- prescribing the symptom, reframing, or changing the frame -- demonstrate how inversion can resolve problems that resist direct attack. The book's core insight is that problems are often maintained by the very logic used to solve them, and that resolution requires stepping outside that logic entirely. For HUMMBL, this grounds the IN transformation's approach to paradoxical and second-order inversion: sometimes the failure mode is not in the system's components but in its governing rules. Inverting the rules themselves -- rather than optimizing within them -- is a distinct class of inversion that Watzlawick's framework makes explicit. The reframing techniques also connect to the P (Perspective) transformation, showing that inversion and perspective-shifting are complementary operations.},
  keywords  = {second-order change, paradoxical intervention, reframing, systems theory, HUMMBL:IN, HUMMBL:P, HUMMBL:SY},
}

@book{Taleb2012Antifragile,
  title     = {Antifragile: Things That Gain from Disorder},
  author    = {Taleb, Nassim Nicholas},
  year      = {2012},
  publisher = {Random House},
  address   = {New York},
  doi-unavailable = {Random House trade book; no DOI assigned},
  isbn      = {9781400067824},
  abstract  = {Taleb introduces the concept of antifragility -- a property of systems that not only survive stress, disorder, and volatility but actually improve from it. This is beyond resilience (which resists shocks and stays the same) and robustness (which absorbs shocks without change). Antifragile systems -- evolution, muscle hypertrophy, trial-and-error innovation -- benefit from randomness and uncertainty. Taleb identifies the "fragilista" as someone who underestimates disorder and over-engineers for stability, inadvertently creating systems that are fragile to tail risks. The book's central inversion: instead of trying to predict and prevent specific failures, design systems that gain from failure. The barbell strategy (90% safe, 10% aggressive) exploits this by keeping most of the system in a robust state while exposing a small portion to high-variance opportunities. For HUMMBL, antifragility is the positive-space counterpart to IN's negative-space analysis: inversion identifies what makes systems fragile, and antifragile design inverts fragility into a source of strength. The concept also challenges the RE (Recursion) transformation: iterative systems should not merely converge to stability but should improve through perturbation. Taleb's "skin in the game" principle connects to governance -- decision-makers must bear the consequences of their decisions to avoid antifragility for themselves at the expense of fragility for others.},
  keywords  = {antifragility, disorder, volatility, tail risk, barbell strategy, HUMMBL:IN, HUMMBL:SY, HUMMBL:RE},
}

@book{Weber1922EconomySociety,
  title     = {Economy and Society: An Outline of Interpretive Sociology},
  author    = {Weber, Max},
  year      = {1922},
  publisher = {University of California Press},
  address   = {Berkeley},
  doi-unavailable = {Posthumous publication (1922); no DOI assigned for the original. Various editions exist.},
  isbn      = {9780520034947},
  abstract  = {Weber's magnum opus introduces the foundational concepts of interpretive sociology: social action (action oriented to the behavior of others), ideal types (analytical constructs that capture the essential features of a phenomenon), and the three types of authority (traditional, charismatic, legal-rational). The book analyzes the rationalization process -- the progressive displacement of tradition and emotion by calculation and efficiency -- across law, politics, religion, and economy. Weber's famous "iron cage" metaphor describes the unintended consequence of rationalization: individuals become trapped in systems of their own making, governed by bureaucratic rules that no one chose but everyone must follow. For HUMMBL, Weber's rationalization thesis provides the sociological framework for understanding how AI governance systems can become iron cages -- bureaucratic structures that constrain the very human judgment they were designed to enable. The ideal type method connects to the DE (Decomposition) transformation.},
  keywords  = {Weber, rationalization, ideal types, authority, iron cage, HUMMBL:DE, HUMMBL:SY, HUMMBL:IN},
}

@book{Burnham1941ManagerialRevolution,
  title     = {The Managerial Revolution: What Is Happening in the World},
  author    = {Burnham, James},
  year      = {1941},
  publisher = {John Day Company},
  address   = {New York},
  doi-unavailable = {Pre-DOI era publication (1941); no DOI assigned},
  isbn      = {9780837156785},
  abstract  = {Burnham argues that capitalism is being replaced not by socialism (as Marx predicted) but by managerialism -- a system in which managers, not owners or workers, control the means of production. The managerial revolution occurs because modern production is too complex for owners to direct directly, requiring a new class of professional managers who possess technical knowledge but not capital. Burnham predicts the convergence of capitalist and socialist systems toward managerialism, with managers in both systems exercising effective control through their monopoly on organizational knowledge. The book influenced Orwell's 1984 and is foundational to the study of bureaucratic power. For HUMMBL, Burnham's thesis provides a framework for understanding AI governance as a potential managerial revolution: AI systems may shift control from domain experts to those who manage the AI infrastructure, creating a new managerial class. The owner-manager-worker triad connects to the DE (Decomposition) transformation.},
  keywords  = {Burnham, managerial revolution, managerialism, bureaucratic power, HUMMBL:DE, HUMMBL:SY, HUMMBL:IN},
}

@book{Chomsky1988ManufacturingConsent,
  title     = {Manufacturing Consent: The Political Economy of the Mass Media},
  author    = {Chomsky, Noam and Herman, Edward S.},
  year      = {1988},
  publisher = {Pantheon Books},
  address   = {New York},
  doi-unavailable = {Pantheon trade book; no DOI assigned},
  isbn      = {9780394554480},
  abstract  = {Chomsky and Herman present the propaganda model of mass media, arguing that corporate media manufactures consent for elite policies through five filters: ownership (media owned by large corporations), advertising (media funded by advertisers, not audiences), sourcing (media relies on official sources), flak (negative responses discipline dissent), and anti-communism (ideological framework for framing threats). The model explains how media can be free from government censorship yet systematically produce content that serves elite interests. For HUMMBL, the propaganda model provides a framework for understanding how AI-mediated information systems can manufacture consent at scale: recommendation algorithms, content moderation, and search ranking are new filters that operate through engagement optimization rather than editorial control. The five-filter model connects to the DE (Decomposition) transformation -- decomposing media bias into distinct filtering mechanisms. The manufacturing-consent concept connects to the IN (Inversion) inversion -- inverting the democratic function of media into a control mechanism.},
  keywords  = {Chomsky, propaganda model, media, manufacturing consent, HUMMBL:DE, HUMMBL:IN, HUMMBL:SY},
}

@book{Gramsci1929PrisonNotebooks,
  title     = {Prison Notebooks},
  author    = {Gramsci, Antonio},
  year      = {1929},
  publisher = {Columbia University Press},
  address   = {New York},
  doi-unavailable = {Prison writings compiled posthumously; no DOI for original notebooks},
  isbn      = {9780231157428},
  abstract  = {Gramsci introduces the concept of cultural hegemony -- the process by which a ruling class maintains power not through coercion but through consent, by shaping the cultural and ideological framework that defines what is thinkable. Hegemony operates through civil society (education, media, religion) rather than the state, making it invisible to those within it. The Prison Notebooks also introduce the concept of the organic intellectual -- a thinker who emerges from a social class and articulates its interests, as opposed to the traditional intellectual who claims neutrality. Gramsci's analysis of hegemony explains why revolution did not occur in the West as Marx predicted: the working class was integrated into the hegemonic culture rather than radicalized by economic conditions. For HUMMBL, cultural hegemony provides the framework for understanding how AI governance frameworks can become hegemonic -- defining what counts as legitimate governance in ways that serve existing power structures. The hegemony-coercion-consent triad connects to the SY (Synthesis) transformation.},
  keywords  = {Gramsci, hegemony, organic intellectual, civil society, HUMMBL:SY, HUMMBL:DE, HUMMBL:IN},
}

