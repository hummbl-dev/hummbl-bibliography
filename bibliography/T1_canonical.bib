  note = {Conceptual ancestry only — not evidence of historical use of the English phrase "grammar of reality." The śabda-brahman tradition establishes a non-Western genealogy for the concept that language and reality share a grammatical structure, but the English phrase is not used. Dating approximate: IEP gives 450-510 CE. Primary text in Sanskrit; cited translation is K.A. Subramania Iyer (Motilal Banarsidass). ISBN 9788120829886 is for Kanda II.},
  abstract = {Bhartṛhari's Vākyapadīya is a foundational work of Indian philosophy of language that posits śabda-brahman (word-monism): the thesis that language and reality are ontologically identical at the ultimate level, with grammar serving as the path to understanding ultimate reality. Bhartṛhari argues that correct grammatical analysis is not merely a linguistic exercise but a direct engagement with the structure of reality itself, since the word principle (śabda-tattva) is the ground of all phenomenal appearance. The Vākyapadīya moves grammatical analysis squarely into the realm of philosophy, arguing that grammar can be considered a darśana (philosophical school) providing insight into ultimate reality. The cited translation is by K.A. Subramania Iyer, published by Motilal Banarsidass.},
  annotation = {This work establishes a non-Western genealogy for the grammar-of-reality concept that predates Kant by over a millennium: where the Western lineage runs through Kant's categories and Wittgenstein's grammar, the Indian lineage runs through Bhartṛhari's śabda-brahman and the grammarians' tradition. For HUMMBL, Bhartṛhari provides a radically different philosophical foundation for the grammar-of-reality metaphor: not a transcendental condition of experience (Kant) or a constitutive framework of meaning (Wittgenstein), but an ontological identity between language and reality that makes grammar the direct study of what is. This widening of the genealogy beyond the Western canon is essential for HUMMBL's claim to universality.},
  keywords = {Bhartṛhari, Vākyapadīya, śabda-brahman, word-monism, Indian philosophy, grammar, ontology, non-Western genealogy, HUMMBL:P, HUMMBL:IN, HUMMBL:CO, HUMMBL:SY}
}

