  doi-unavailable = {Original 1964 publication; MIT Press edition. No DOI assigned.},
  isbn      = {9780262631594},
  abstract  = {McLuhan introduces the concept that "the medium is the message" -- the content of a medium is less important than the structural changes it produces in human perception and social organization. Media are extensions of the human nervous system: the wheel extends the foot, the book extends the eye, electronic media extend the central nervous system. McLuhan distinguishes hot media (high definition, low participation) from cool media (low definition, high participation). The book predicts that electronic media would end the Gutenberg galaxy (the linear, sequential thinking fostered by print) and return humanity to a tribal mode of simultaneous, multi-sensory experience. For HUMMBL, McLuhan's framework provides the media-theoretical foundation for understanding AI as a medium: AI extends human cognition, and the structural changes it produces (automation of judgment, acceleration of decision) are more significant than any particular AI output. The medium-message distinction connects to the P (Perspective) transformation.},
  keywords  = {McLuhan, media, medium is the message, extensions, HUMMBL:P, HUMMBL:SY, HUMMBL:DE},
}

@book{Veblen1899LeisureClass,
  title     = {The Theory of the Leisure Class},
  author    = {Veblen, Thorstein},
  year      = {1899},
  publisher = {Oxford University Press},
  address   = {New York},
  doi-unavailable = {1899 publication; no DOI for original. Oxford World Classics edition ISBN provided.},
  isbn      = {9780199552580},
  abstract  = {Veblen introduces the concept of conspicuous consumption -- the purchase and display of goods not for utility but to signal social status. The leisure class engages in conspicuous leisure (non-productive time use) and conspicuous consumption (non-utilitarian expenditure) to demonstrate freedom from productive labor. Veblen argues that these behaviors are not irrational but follow the logic of status competition: in societies where wealth confers status, the visible waste of resources becomes the primary means of status display. The book introduces the concept of pecuniary emulation -- the adoption of upper-class consumption patterns by lower classes, creating a cascading status competition. For HUMMBL, Veblen's framework provides the economic-sociological foundation for understanding AI consumption patterns: conspicuous computation (using expensive AI models to signal sophistication rather than solve problems) and pecuniary emulation in AI adoption. The conspicuous consumption concept connects to the IN (Inversion) inversion -- inverting the appearance of utility to reveal status competition.},
  keywords  = {Veblen, conspicuous consumption, leisure class, status, emulation, HUMMBL:IN, HUMMBL:DE, HUMMBL:SY},
}

@book{Pareto1935MindSociety,
  title     = {The Mind and Society (Trattato di Sociologia Generale)},
  author    = {Pareto, Vilfredo},
  year      = {1935},
  publisher = {Dover Publications},
  address   = {New York},
  doi-unavailable = {Italian original 1916; English translation 1935. No DOI for original. Dover edition.},
  isbn      = {9780486794075},
  abstract  = {Pareto distinguishes between logical actions (actions that are instrumentally rational) and non-logical actions (actions driven by sentiments and residues). He identifies six classes of residues -- the persistent emotional patterns that underlie non-logical action -- including the residue of combinations (innovation), the persistence of aggregates (conservatism), and the residue of sentiments. Pareto argues that elites maintain power through a combination of force and persuasion (derivations), and that elite circulation -- the replacement of one elite by another -- is the primary mechanism of social change. The concept of residues provides a framework for understanding why logical arguments often fail to change behavior: the underlying residues, not the surface arguments, drive action. For HUMMBL, Pareto's logical/non-logical distinction connects to the IN (Inversion) inversion -- inverting the surface argument to reveal the underlying residue. The elite circulation concept connects to the RE (Recursion) transformation.},
  keywords  = {Pareto, residues, elite circulation, non-logical action, HUMMBL:IN, HUMMBL:RE, HUMMBL:SY},
}

@book{IbnKhaldun1377Muqaddimah,
  title     = {The Muqaddimah: An Introduction to History},
  author    = {Ibn Khaldun},
  year      = {1377},
  publisher = {Princeton University Press},
  address   = {Princeton, NJ},
  doi-unavailable = {14th century manuscript; no DOI. Princeton University Press English edition ISBN provided.},
  isbn      = {9780691120064},
  abstract  = {Ibn Khaldun's Muqaddimah is considered the first work of sociology and historiography, introducing the concept of asabiyyah (social cohesion/group solidarity) as the driving force of historical change. Ibn Khaldun argues that dynasties rise through asabiyyah (the solidarity of desert tribes), establish cities and luxury, and then decline as luxury erodes asabiyyah -- a cyclical theory of history with a typical dynasty lifespan of three generations. He analyzes the economic effects of taxation (high taxes reduce revenue by discouraging production), the role of religion in strengthening asabiyyah, and the distinction between rural (tough, cohesive) and urban (soft, fragmented) society. For HUMMBL, Ibn Khaldun's asabiyyah concept provides a foundational framework for understanding organizational cohesion and decline: AI governance systems, like dynasties, may rise through technical cohesion and decline as institutional complexity erodes the original solidarity. The cyclical theory connects to the RE (Recursion) transformation.},
  keywords  = {Ibn Khaldun, asabiyyah, social cohesion, cyclical history, HUMMBL:RE, HUMMBL:SY, HUMMBL:DE},
}
