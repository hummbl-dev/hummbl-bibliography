@book{Pearson1892GrammarScience,
  title = {The Grammar of Science},
  author = {Pearson, Karl},
  year = {1892},
  publisher = {Adam \& Charles Black},
  isbn = {978-0486425388},
  % No DOI available -- 1892 original; Dover reprint ISBN has no registered DOI
  abstract = {This foundational work articulates the view that science possesses a grammar—a structured set of rules governing method, explanation, and the categories through which phenomena are rendered intelligible. Pearson argues that scientific laws are not discoveries of external necessities but concise descriptions of regularities in sensation, and that the scientific method itself constitutes a disciplined grammar for processing experience. He treats causation, probability, and classification as grammatical categories that organize inquiry rather than metaphysical discoveries about the world. The book's framing of science as a rule-governed linguistic and conceptual practice anticipates later structuralist and constructivist epistemologies, and its emphasis on the contingency of scientific categories resonates with HUMMBL's treatment of cognitive transformations as governed operations on a base vocabulary. Einstein read this work intensively in the Olympia Academy, and its influence is visible in his approach to physical theory as a coherent grammatical system rather than a collection of empirical findings. For HUMMBL, Pearson provides the lexical precedent for treating any domain—science, governance, cognition—as having a grammar that determines what can be said, thought, and legitimately inferred within it.},
  keywords = {philosophy of science, scientific method, grammar of reality, categories of explanation, HUMMBL:P, HUMMBL:IN, HUMMBL:CO}
}

@book{Kant1781CritiquePureReason,
  title = {Critique of Pure Reason},
  author = {Kant, Immanuel},
  year = {1787},
  publisher = {Cambridge University Press},
  isbn = {978-0521657297},
  % No DOI available -- 1781/1787 original; Cambridge translation ISBN has no registered DOI
  abstract = {This monumental work establishes the framework of transcendental philosophy, arguing that experience is structured by a priori categories—the synthetic principles of understanding that function as the syntax of all possible experience. Kant demonstrates that concepts such as causality, substance, and unity are not derived from experience but are preconditions that make experience coherent, functioning as a fixed grammar through which the mind organizes sensory manifold into intelligible objects. The Critique introduces the distinction between phenomena (things as they appear under the grammatical constraints of understanding) and noumena (things in themselves, beyond the reach of that grammar), establishing limits on what can be known. This architecture maps directly onto HUMMBL's concern with cognitive transformations as governed operations: the categories are the base vocabulary of possible experience, and the synthetic a priori judgments are the transformation rules that generate the space of knowable reality. Kant's demonstration that finite rules can generate the full space of possible experience provides the philosophical template for Base120's premise that a bounded set of primitive operations can compose all higher-order cognitive structures. The work remains the canonical treatment of the conditions of intelligibility.},
  keywords = {epistemology, transcendental philosophy, categories, a priori, syntax of experience, HUMMBL:P, HUMMBL:IN, HUMMBL:CO}
}

@book{Wittgenstein1921Tractatus,
  title = {Tractatus Logico-Philosophicus},
  author = {Wittgenstein, Ludwig},
  year = {1921},
  publisher = {Routledge},
  isbn = {978-0415251858},
  doi = {10.4324/9781315110739},
  abstract = {This compressed and enigmatic work argues that language and reality share a common logical form—a grammar that neither can state but that makes both representation and fact possible. Wittgenstein proposes that propositions are pictures of states of affairs, and that the logical scaffolding of language mirrors the logical scaffolding of the world. The Tractatus delineates the limits of what can be meaningfully said, concluding that the grammar of logic is shown in every meaningful proposition but cannot itself be propositionally expressed. This conception of a shared logical form as the hidden infrastructure of both thought and world provides a direct philosophical antecedent to HUMMBL's treatment of Base120 as a generative grammar: a finite set of logical primitives whose combinatorial rules produce the entire space of expressible states. The work's insistence that the structure of representation is not a content of representation but its condition parallels HUMMBL's distinction between transformation rules and the content they operate on. The Tractatus also introduces the picture theory of meaning, the truth-functional analysis of propositions, and the famous closing injunction to silence regarding what cannot be said, establishing the limits of grammatical articulation.},
  keywords = {logical form, philosophy of language, picture theory, logical atomism, grammar of reality, HUMMBL:P, HUMMBL:IN, HUMMBL:CO}
}

@book{Wittgenstein1953PhilosophicalInvestigations,
  title = {Philosophical Investigations},
  author = {Wittgenstein, Ludwig},
  year = {1953},
  edition = {4th},
  publisher = {Wiley-Blackwell},
  isbn = {978-0631231271},
  doi = {10.1002/9781444310526},
  abstract = {This posthumous work overturns the Tractarian picture of a single logical form shared by language and world, replacing it with the conception of grammar as constitutive of meaning within diverse language games embedded in forms of life. Wittgenstein argues that meaning is not a relation between word and object but is determined by the use of expressions within rule-governed practices. He introduces the concept of thick grammar—grammatical rules that are not merely formal but are interwoven with empirical practices, institutions, and human activities, making grammar reality-soaked rather than a neutral logical skeleton. The Investigations explores how rules determine their own applications, the private language argument, and the impossibility of drawing a sharp boundary between grammatical and empirical propositions. This reconception of grammar as the autonomous, constitutive framework of meaning provides HUMMBL with its central philosophical resource: the idea that cognitive transformations are governed not by external logical structures but by the internal grammar of the practices in which they occur. The work's treatment of rule-following and forms of life directly informs HUMMBL's account of how Base120 operations are grounded in shared cognitive and institutional practices rather than in abstract formal logic alone.},
  keywords = {philosophy of language, language games, forms of life, thick grammar, rule-following, meaning as use, HUMMBL:P, HUMMBL:IN, HUMMBL:CO}
}

@book{Wittgenstein1969OnCertainty,
  title = {On Certainty},
  author = {Wittgenstein, Ludwig},
  year = {1969},
  publisher = {Wiley-Blackwell},
  isbn = {978-0631231134},
  doi = {10.1002/9781444312773},
  abstract = {This final work reconceives the relationship between grammar and empirical reality by introducing the concept of hinge propositions—certainties that function as the immovable framework within which all doubt, inquiry, and verification take place. Wittgenstein argues that these hinge certainties are neither knowledge nor ignorance but stand outside the epistemic game entirely, forming the bedrock that must remain unshaken for any questioning to be coherent. He demonstrates that grammar, in its thick sense, becomes reality-soaked: the grammatical rules that structure our world-picture are not insulated from empirical engagement but are hardened into place through practice, taking on the role of the riverbed that shapes the flow of empirical propositions and can, over geological time, itself shift. This account provides HUMMBL with a model for understanding how cognitive transformations rest on unarticulated certainties that are neither arbitrary conventions nor empirical discoveries but are the grammatical infrastructure of intelligibility itself. The grammaticalization of experience—the process by which repeated empirical engagement solidifies into hinge certainty—maps onto HUMMBL's concern with how Base120 primitives become stabilized through use and how governance frameworks harden into the presuppositions of subsequent reasoning. The work is the definitive treatment of the boundary between grammatical and empirical propositions.},
  keywords = {epistemology, hinge certainty, grammar, skepticism, reality-soaked grammar, grammaticalization of experience, HUMMBL:P, HUMMBL:IN, HUMMBL:CO, HUMMBL:DE}
}

@book{Heidegger1927BeingTime,
  title = {Being and Time},
  author = {Heidegger, Martin},
  year = {1927},
  publisher = {Blackwell},
  isbn = {978-0631194562},
  % No DOI available -- 1927 German original; Blackwell English edition has no registered DOI
  abstract = {This foundational work of twentieth-century philosophy undertakes the question of the meaning of being through an analytic of Dasein—the entity for whom being is an issue. Heidegger argues that intelligibility—the disclosedness of beings as something—is not a property of isolated subjects but is constituted through Dasein's situated engagement in a world, structured by care, temporality, and projection. The work introduces the ontological difference between being and beings, and demonstrates that the structures through which beings become intelligible—the existentialia—function as a grammar of being: a set of constitutive structures that determine what can appear as a being, how it can be encountered, and within what horizon of sense. This conception of an ontological grammar as the condition for the appearance of any entity provides HUMMBL with a deep philosophical parallel: Base120's cognitive transformations are not operations performed on pre-given realities but are the structures through which reality becomes articulable in the first place. Heidegger's treatment of thrownness, projection, and temporality as the structural conditions of intelligibility informs HUMMBL's account of how cognitive operations are always already situated within historical and practical contexts that shape their grammar from the outset.},
  keywords = {ontology, phenomenology, Dasein, intelligibility, grammar of being, ontological difference, HUMMBL:P, HUMMBL:IN, HUMMBL:CO, HUMMBL:SY}
}

@book{Whitehead1929ProcessReality,
  title = {Process and Reality: An Essay in Cosmology},
  author = {Whitehead, Alfred North},
  year = {1929},
  edition = {Corrected},
  publisher = {Free Press},
  isbn = {978-0029345702},
  % No DOI available -- 1929 Macmillan original; corrected Free Press edition has no registered DOI
  abstract = {This ambitious work of speculative philosophy proposes a process metaphysics in which reality is constituted not by enduring substances but by actual occasions—momentary events of becoming that achieve determinate form through their prehensions of other occasions. Whitehead argues that the categories of traditional substance metaphysics are inadequate to the nature of reality and must be replaced by a categorial scheme in which process, relation, and creativity are fundamental. This shift from substance to event is, at its deepest level, a grammatical shift in ontology: it changes the base vocabulary of what counts as a real entity and the transformation rules by which entities combine into societies. Whitehead's scheme of categories—including actual entities, prehensions, nexus, and eternal objects—functions as a generative grammar for cosmology, producing the full diversity of cosmic processes from a finite set of categorical primitives. For HUMMBL, this provides a paradigmatic example of how a change in base vocabulary and transformation rules produces an entirely different space of expressible states, demonstrating that the grammar of a domain is not neutral but constitutive of what can appear within it. The work also introduces the extensive continuum and the principle of relativity, grounding process in a rigorous categorial framework.},
  keywords = {process metaphysics, actual occasions, cosmology, ontology, grammatical shift, HUMMBL:P, HUMMBL:IN, HUMMBL:CO, HUMMBL:SY}
}

@book{Bohm1980WholenessImplicate,
  title = {Wholeness and the Implicate Order},
  author = {Bohm, David},
  year = {1980},
  publisher = {Routledge},
  isbn = {978-0415283855},
  doi = {10.4324/9780203950870},
  abstract = {This work proposes a fundamental reconception of reality in terms of the distinction between implicate and explicate orders. Bohm argues that the apparent fragmentation of the world into separate, independently existing objects is a product of the explicate order—the unfolded, manifest level of reality—while the deeper implicate order enfolds the whole into each part, making reality an undivided totality in constant process. He introduces the rheomode, an experimental linguistic structure designed to make process rather than substance the primary grammatical category, demonstrating that the grammar of substance-based language may itself obscure the processual nature of reality. This linguistic experiment directly exemplifies HUMMBL's concern with how the grammar of a domain—its base vocabulary and transformation rules—shapes what can be articulated within it: a substance grammar yields a world of things, while a process grammar yields a world of events and flows. Bohm's treatment of wholeness as prior to parts, and of explication as a grammatical operation that unfolds the implicate into the manifest, provides HUMMBL with a model for understanding cognitive transformations as operations that explicate structure from a base that is itself grammatically structured. The work bridges physics, philosophy of language, and epistemology, making the grammar of process vs substance its central thematic contribution.},
  keywords = {implicate order, process philosophy, rheomode, wholeness, grammar of process, HUMMBL:P, HUMMBL:IN, HUMMBL:CO, HUMMBL:SY}
}

@incollection{Hacker2002WittgensteinGrammar,
  title = {Wittgenstein's Grammar: Through Thick and Thin},
  author = {Hacker, P. M. S.},
  booktitle = {Wittgenstein: Connections and Controversies},
  year = {2002},
  publisher = {Oxford University Press},
  isbn = {978-0199254019},
  doi = {10.1093/0199254012.001.0001},
  abstract = {This chapter provides the canonical scholarly treatment of Wittgenstein's conception of grammar as constitutive of meaning, tracing its evolution from the thin, purely logical grammar of the Tractatus to the thick, reality-soaked grammar of the later and final works. Hacker demonstrates that Wittgenstein's notion of grammar undergoes a profound transformation: in the early period, grammar consists of the logical scaffolding shared by language and world, formal and content-neutral; in the Philosophical Investigations, grammar becomes the autonomous network of rules that constitutes meaning within language games and forms of life, interwoven with practice and institution; and in On Certainty, grammar becomes fully reality-soaked, with hinge propositions blurring the boundary between grammatical rules and empirical claims. Hacker argues that this trajectory reveals grammar to be not a static formal structure but a dynamic, practice-embedded framework that hardens and shifts through use. For HUMMBL, this genealogy is indispensable: it provides the scholarly foundation for the claim that cognitive transformations are governed by grammars that evolve from thin logical primitives to thick, reality-soaked structures through repeated application in practice. The chapter clarifies the distinction between grammatical and empirical propositions, the autonomy of grammar, and the sense in which grammar determines what counts as sense, making it the definitive reference for HUMMBL's grammatical framework.},
  keywords = {Wittgenstein, grammar, thick grammar, thin grammar, philosophy of language, constitutive rules, HUMMBL:P, HUMMBL:IN, HUMMBL:CO, HUMMBL:DE}
}
