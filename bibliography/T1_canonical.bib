}

@article{Heidegger1954QuestionTechnology,
  title     = {The Question Concerning Technology},
  author    = {Heidegger, Martin},
  year      = {1954},
  journal   = {The Question Concerning Technology and Other Essays (1977 English translation)},
  pages     = {3--35},
  doi-unavailable = {Essay originally in German (1954); English translation in 1977 Harper collection. No DOI.},
  abstract  = {Heidegger argues that technology is not merely a tool but a way of revealing -- a mode of bringing forth truth that he calls Gestell (enframing). Under enframing, everything is revealed as Bestand (standing reserve), a resource to be optimized and consumed. The danger of technology is not that it might malfunction but that it might succeed: that the technological way of revealing might crowd out all other ways of understanding being. Heidegger argues that the essence of technology is nothing technological -- it is a mode of understanding that precedes and shapes any particular technology. For HUMMBL, Heidegger's analysis provides the deepest philosophical critique of AI governance: the danger is not that AI might fail but that it might succeed in reducing all decision-making to optimization, crowding out other modes of understanding. The enframing-standing-reserve framework connects to the IN (Inversion) inversion -- inverting the tool to reveal the way of revealing.},
  keywords  = {Heidegger, technology, enframing, standing reserve, revealing, HUMMBL:IN, HUMMBL:P, HUMMBL:SY},
}

