% T7_emerging.bib — Emerging AI Agent Research (2020-2025)
% Added 2026-03-23 to ground hummbl-dev's agent implementations in literature
%
% These entries cover cutting-edge research on LLM-based agents, tool use,
% retrieval-augmented generation, agent evaluation, multi-model routing,
% and prompt engineering — patterns that founder-mode, hybrid-inference,
% autoresearch, swarm-test, and forge actively implement.

@inproceedings{Yao2023ReAct,
  title = {ReAct: Synergizing Reasoning and Acting in Language Models},
  author = {Yao, Shunyu and Zhao, Jeffrey and Yu, Dian and Du, Nan and Shafran, Izhak and Narasimhan, Karthik and Cao, Yuan},
  year = {2023},
  booktitle = {Proceedings of the Eleventh International Conference on Learning Representations (ICLR 2023)},
  url = {https://arxiv.org/abs/2210.03629},
  abstract = {This paper introduces ReAct, a framework that interleaves reasoning traces and task-specific actions in LLMs. By generating verbal reasoning (``thoughts'') alongside actions, the model can create, maintain, and adjust plans while also interacting with external environments to incorporate new information. ReAct outperforms chain-of-thought reasoning alone on knowledge-intensive tasks (HotpotQA, FEVER) and decision-making tasks (ALFWorld, WebShop). The key insight is that reasoning helps the model track progress and handle exceptions, while acting lets it gather information from the external world. Every agent in the founder-mode fleet --- from the briefing scheduler to the forge workers --- implements this think-then-act loop: the coordination bus captures the ``thought'' trace, and tool calls (gh, linear, calendar) execute the ``action'' step.},
  keywords = {reasoning, acting, tool use, agent architecture, HUMMBL:CO, HUMMBL:RE, HUMMBL:SY}
}

@inproceedings{Wei2022ChainOfThought,
  title = {Chain-of-Thought Prompting Elicits Reasoning in Large Language Models},
  author = {Wei, Jason and Wang, Xuezhi and Schuurmans, Dale and Bosma, Maarten and Ichter, Brian and Xia, Fei and Chi, Ed and Le, Quoc V. and Zhou, Denny},
  year = {2022},
  booktitle = {Advances in Neural Information Processing Systems 35 (NeurIPS 2022)},
  url = {https://arxiv.org/abs/2201.11903},
  abstract = {This paper demonstrates that generating a chain of intermediate reasoning steps (chain-of-thought) significantly improves the ability of large language models to perform complex reasoning. Using few-shot prompting with exemplars that include step-by-step reasoning, the authors show substantial improvements on arithmetic, commonsense, and symbolic reasoning benchmarks. The effect is an emergent ability of model scale: chain-of-thought prompting does not help smaller models but produces dramatic gains in models with approximately 100B+ parameters. The paper establishes that the format of prompts --- not just their content --- fundamentally shapes model capabilities. Every prompt in the hummbl-dev ecosystem, from briefing generation to code review to Base120 model application, relies on structured reasoning chains to elicit reliable, auditable outputs from frontier models.},
  keywords = {chain-of-thought, prompting, emergent abilities, reasoning, HUMMBL:DE, HUMMBL:RE, HUMMBL:P}
}

@inproceedings{Lewis2020RAG,
  title = {Retrieval-Augmented Generation for Knowledge-Intensive NLP Tasks},
  author = {Lewis, Patrick and Perez, Ethan and Piktus, Aleksandra and Petroni, Fabio and Karpukhin, Vladimir and Goyal, Naman and K\"{u}ttler, Heinrich and Lewis, Mike and Yih, Wen-tau and Rockt\"{a}schel, Tim and Riedel, Sebastian and Kiela, Douwe},
  year = {2020},
  booktitle = {Advances in Neural Information Processing Systems 33 (NeurIPS 2020)},
  url = {https://arxiv.org/abs/2005.11401},
  abstract = {This paper introduces Retrieval-Augmented Generation (RAG), which combines a pre-trained parametric memory (a seq2seq model) with a non-parametric memory (a dense vector index of Wikipedia) accessed via a neural retriever. The model learns to retrieve relevant passages and use them to generate answers, outperforming purely parametric models on knowledge-intensive tasks including open-domain QA, fact verification, and Jeopardy question generation. RAG can be updated without retraining by simply swapping the knowledge index. The Cognitive Ledger Protocol (CLP) in founder-mode implements a form of RAG: the retriever module searches across five memory pools (ledger, bus, briefings, findings, MEMORY.md) using BM25 indexing, and the results are injected as context for the boot\_context session initialization. The consolidator on nodezero periodically synthesizes these retrievals into denser representations.},
  keywords = {retrieval-augmented generation, knowledge base, non-parametric memory, HUMMBL:CO, HUMMBL:RE, HUMMBL:SY}
}

@inproceedings{Schick2023Toolformer,
  title = {Toolformer: Language Models Can Teach Themselves to Use Tools},
  author = {Schick, Timo and Dwivedi-Yu, Jane and Dess\`{i}, Roberto and Raileanu, Roberta and Lomeli, Maria and Zettlemoyer, Luke and Cancedda, Nicola and Scialom, Thomas},
  year = {2023},
  booktitle = {Advances in Neural Information Processing Systems 36 (NeurIPS 2023)},
  url = {https://arxiv.org/abs/2302.04761},
  abstract = {Toolformer demonstrates that language models can learn to use external tools (calculators, search engines, calendars, translation systems, Q\&A APIs) in a self-supervised manner by generating API calls within text sequences. The model decides which APIs to call, when to call them, what arguments to pass, and how to incorporate results into its generation --- all without explicit tool-use training data from humans. The key technique is filtering self-generated API calls by whether they reduce perplexity on future tokens. This is the theoretical foundation for tool-augmented agents: the MCP server in hummbl-dev exposes Base120 models as a tool API, the GitHub/Linear/Calendar integrations in founder-mode are invoked as tool calls during briefing generation, and the forge workers execute tool calls to accomplish their sub-tasks.},
  keywords = {tool use, API calls, self-supervised learning, HUMMBL:CO, HUMMBL:DE, HUMMBL:SY}
}

@inproceedings{Liu2024AgentBench,
  title = {AgentBench: Evaluating LLMs as Agents},
  author = {Liu, Xiao and Yu, Hao and Zhang, Hanchen and Xu, Yifan and Lei, Xuanyu and Lai, Hanyu and Gu, Yu and Ding, Hangliang and Men, Kaiwen and Yang, Kejuan and Zhang, Shudan and Deng, Xiang and Zeng, Aohan and Du, Zhengxiao and Zhang, Chenhui and Shen, Sheng and Zhang, Tianjun and Su, Yu and Sun, Huan and Huang, Minlie and Dong, Yuxiao and Tang, Jie},
  year = {2024},
  booktitle = {Proceedings of the Twelfth International Conference on Learning Representations (ICLR 2024)},
  url = {https://arxiv.org/abs/2308.03688},
  abstract = {AgentBench provides a multi-dimensional benchmark for evaluating LLMs as agents across 8 distinct environments: operating system interaction, database querying, knowledge graph reasoning, digital card games, lateral thinking puzzles, household tasks, web shopping, and web browsing. The benchmark reveals a significant gap between commercial and open-source LLMs in agentic capabilities, with GPT-4 substantially outperforming all other models. The paper establishes that agentic ability is partially orthogonal to traditional NLP benchmarks, meaning models that score well on static tasks may fail at multi-step agent interactions. This is directly relevant to the hybrid-inference routing policy in hummbl-dev: not all models are equal for agentic tasks, and the router must select the right model for the right task rather than defaulting to the cheapest option.},
  keywords = {agent evaluation, benchmarks, agentic capabilities, HUMMBL:IN, HUMMBL:DE, HUMMBL:SY}
}

@inproceedings{Jimenez2024SWEBench,
  title = {SWE-bench: Can Language Models Resolve Real-World GitHub Issues?},
  author = {Jimenez, Carlos E. and Yang, John and Wettig, Alexander and Yao, Shunyu and Pei, Kexin and Press, Ofir and Narasimhan, Karthik R.},
  year = {2024},
  booktitle = {Proceedings of the Twelfth International Conference on Learning Representations (ICLR 2024)},
  url = {https://arxiv.org/abs/2310.06770},
  abstract = {SWE-bench presents 2,294 software engineering problems drawn from real GitHub issues and corresponding pull requests across 12 popular Python repositories. Unlike synthetic coding benchmarks, SWE-bench requires models to understand entire codebases, localize bugs, and produce patches that pass existing test suites. The best models at introduction solved only 1.96\% of tasks, establishing the enormous difficulty of autonomous software engineering. The benchmark has since become the primary measure of agentic coding capability, with specialized systems like SWE-Agent and Devin pushing resolution rates above 30\%. The swarm-test architecture at hummbl-dev (12-terminal parallel Claude swarm) and the arbiter code quality system directly address this problem space: coordinating multiple agents to understand, modify, and validate changes across a large real-world codebase.},
  keywords = {software engineering, coding agents, benchmarks, HUMMBL:DE, HUMMBL:RE, HUMMBL:IN}
}

@article{Wang2024LLMAgentSurvey,
  title = {A Survey on Large Language Model based Autonomous Agents},
  author = {Wang, Lei and Ma, Chen and Feng, Xueyang and Zhang, Zeyu and Yang, Hao and Zhang, Jingsen and Chen, Zhiyuan and Tang, Jiakai and Chen, Xu and Lin, Yankai and Zhao, Wayne Xin and Wei, Zhenhua and Wen, Ji-Rong},
  year = {2024},
  journal = {Frontiers of Computer Science},
  volume = {18},
  number = {6},
  doi = {10.1007/s11704-024-40231-1},
  abstract = {This comprehensive survey reviews the field of LLM-based autonomous agents from three perspectives: construction (profiling, memory, planning, and action modules), application (social simulation, natural science, engineering), and evaluation (subjective, objective, and benchmark-based). The survey identifies four key architectural components that every LLM agent requires: a profile that shapes behavior, a memory system for storing and retrieving experience, a planning mechanism for task decomposition and scheduling, and an action interface for tool use and environment interaction. This four-component framework maps precisely onto the founder-mode agent architecture: agent identity files (profile), the Cognitive Ledger + MEMORY.md (memory), the scheduler and sprint recommender (planning), and the 7 integration adapters (action).},
  keywords = {LLM agents, autonomous agents, agent architecture, survey, HUMMBL:SY, HUMMBL:CO, HUMMBL:DE}
}

@inproceedings{Chen2023FrugalGPT,
  title = {FrugalGPT: How to Use Large Language Models While Reducing Cost and Improving Performance},
  author = {Chen, Lingjiao and Zaharia, Matei and Zou, James},
  year = {2023},
  booktitle = {Transactions on Machine Learning Research (TMLR)},
  url = {https://arxiv.org/abs/2305.05176},
  abstract = {FrugalGPT introduces three strategies for reducing LLM inference costs: prompt adaptation (shortening prompts), LLM approximation (fine-tuning smaller models to mimic larger ones), and LLM cascade (routing queries through a sequence of models from cheapest to most expensive, stopping when confidence is sufficient). The LLM cascade approach can match GPT-4 performance with up to 98\% cost reduction by using cheaper models for easy queries and reserving expensive models for hard ones. The core insight --- that most queries do not need the most powerful model --- directly motivates the hybrid-inference policy router at hummbl-dev, which routes between local Ollama models (qwen3.5) and cloud APIs based on task complexity, and the CostGovernorBridge that enforces budget ceilings across all adapter calls.},
  keywords = {cost optimization, LLM cascade, model routing, HUMMBL:DE, HUMMBL:IN, HUMMBL:SY}
}

@inproceedings{Ong2024RouteLLM,
  title = {RouteLLM: Learning to Route LLMs with Preference Data},
  author = {Ong, Isaac and Almahairi, Amjad and Wu, Vincent and Chiang, Wei-Lin and Wu, Tianhao and Gonzalez, Joseph E. and Kadous, M Waleed and Stoica, Ion},
  year = {2024},
  booktitle = {Proceedings of the Thirteenth International Conference on Learning Representations (ICLR 2025)},
  url = {https://arxiv.org/abs/2406.18665},
  abstract = {RouteLLM trains lightweight router models that dynamically select between a stronger and weaker LLM at inference time, optimizing the cost-quality tradeoff. Using human preference data from Chatbot Arena and data augmentation techniques, the routers learn to predict when a cheaper model will produce a response of comparable quality to an expensive one. The framework achieves over 2x cost reduction without degrading response quality, and the trained routers generalize across model pairs. This work provides the academic foundation for the routing decision that hybrid-inference makes on every query: the policy engine evaluates task requirements against model capabilities and cost, selecting the optimal model from the available fleet (local Ollama, Claude, GPT, etc.).},
  keywords = {model routing, cost optimization, preference learning, HUMMBL:DE, HUMMBL:IN, HUMMBL:RE}
}

@inproceedings{Shinn2023Reflexion,
  title = {Reflexion: Language Agents with Verbal Reinforcement Learning},
  author = {Shinn, Noah and Cassano, Federico and Gopinath, Ashwin and Narasimhan, Karthik and Yao, Shunyu},
  year = {2023},
  booktitle = {Advances in Neural Information Processing Systems 36 (NeurIPS 2023)},
  url = {https://arxiv.org/abs/2303.11366},
  abstract = {Reflexion introduces a framework where language agents learn from their mistakes through verbal self-reflection rather than weight updates. After a failed attempt at a task, the agent generates a natural language reflection analyzing what went wrong, and stores this reflection in an episodic memory buffer that informs future attempts. This achieves state-of-the-art results on decision-making (AlfWorld), reasoning (HotpotQA), and programming (HumanEval) tasks. The key insight is that language itself can serve as the reinforcement signal --- no gradient updates required. The Cognitive Ledger Protocol implements this pattern: agents post reflections to the ledger after completing tasks, and boot\_context injects these reflections into future sessions, enabling cross-session learning without model fine-tuning.},
  keywords = {self-reflection, verbal reinforcement, episodic memory, agent learning, HUMMBL:RE, HUMMBL:IN, HUMMBL:P}
}

@article{Schulhoff2024PromptReport,
  title = {The Prompt Report: A Systematic Survey of Prompting Techniques},
  author = {Schulhoff, Sander and Ilie, Michael and Balepur, Nishant and Kahadze, Konstantine and Liu, Amanda and Si, Chenglei and Li, Yinheng and Gupta, Aayush and Han, HyoJung and Schulhoff, Sevien and others},
  year = {2024},
  journal = {arXiv preprint},
  url = {https://arxiv.org/abs/2406.06608},
  abstract = {The most comprehensive survey of prompt engineering to date, analyzing 1,565 papers to produce a taxonomy of 58 text-based prompting techniques and 40 techniques for other modalities, along with 33 standardized vocabulary terms. The survey categorizes techniques by function: zero-shot (role prompting, emotion prompting, SimToM), few-shot (chain-of-thought, self-consistency, tree-of-thought), thought generation, decomposition, ensembling, and self-criticism. By establishing prompt engineering as a systematic discipline with reproducible techniques rather than ad-hoc craft, this work provides the theoretical vocabulary for how every agent in the hummbl-dev fleet is instructed: from the apex agent definition to the 130 Claude Code skills, each of which embodies specific prompting patterns from this taxonomy.},
  keywords = {prompt engineering, survey, taxonomy, techniques, HUMMBL:DE, HUMMBL:CO, HUMMBL:P}
}

@article{Wang2023Voyager,
  title = {Voyager: An Open-Ended Embodied Agent with Large Language Models},
  author = {Wang, Guanzhi and Xie, Yuqi and Jiang, Yunfan and Mandlekar, Ajay and Xiao, Chaowei and Zhu, Yuke and Fan, Linxi and Anandkumar, Anima},
  year = {2023},
  journal = {arXiv preprint},
  url = {https://arxiv.org/abs/2305.16291},
  abstract = {Voyager is the first LLM-powered embodied lifelong learning agent, demonstrated in Minecraft. It consists of three components: an automatic curriculum that maximizes exploration, an ever-growing skill library of executable code for storing and retrieving complex behaviors, and an iterative prompting mechanism with environment feedback and self-verification. Voyager obtains 3.3x more unique items, travels 2.3x longer distances, and unlocks key tech tree milestones up to 15.3x faster than prior methods --- all without gradient-based training. The skill library pattern --- where successful solutions are stored as reusable code and retrieved by semantic similarity for future tasks --- is implemented in the Claude Code skills system (130 skills) and the forge worker library, where successful task patterns are captured and reused across sessions.},
  keywords = {lifelong learning, skill library, embodied agents, exploration, HUMMBL:RE, HUMMBL:CO, HUMMBL:SY}
}
