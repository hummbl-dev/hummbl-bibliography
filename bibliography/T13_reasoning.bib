@article{McGinn2024GrammarReality,
  author    = {McGinn, Marie},
  title     = {On the Relations Between Grammar and Reality: A {Wittgensteinian} Study},
  journal   = {Analysis: Journal of Philosophical Research, University of Zaragoza},
  year      = {2024},
  url       = {https://papiro.unizar.es/ojs/index.php/analisis/en/article/view/4189},
  % No DOI available -- open-access journal article; DOI not registered
  abstract  = {McGinn argues, against Moyal-Sharrock's non-cognitivist reading of Wittgenstein, that the relation between grammar and reality is bidirectional: reality permeates grammar AND grammar permeates reality. Grammar is not a self-enclosed autonomous system of rules divorced from the world; rather, grammatical categories are shaped by, and in turn shape, what counts as a fact. This reciprocal determination challenges both realist accounts that treat language as a transparent medium and conventionalist accounts that sever grammar from reality entirely.},
  annotation  = {For HUMMBL, McGinn's bidirectional thesis maps directly onto the Base120 cognitive transformation framework: the IN (internalization) and CO (composition) transformations are not one-way encodings of pre-given reality but bidirectional channels through which structured possibility and empirical constraint co-determine each other. The argument reframes the epistemological stakes of reasoning systems: a reasoning engine's grammar (its representational primitives, type system, and inference rules) is simultaneously a claim about how reality can be organized and a product of how reality has already organized our practices.},
  keywords  = {Wittgenstein, grammar, reality, epistemology, philosophy of language, HUMMBL:IN, HUMMBL:CO, HUMMBL:DE, HUMMBL:RE},
  doi-unavailable = {Open-access journal article (Analysis, University of Zaragoza); DOI not registered by publisher; available at papiro.unizar.es/ojs/index.php/analisis/en/article/view/4189},
}

@online{Peat2002RoleLanguage,
  author    = {Peat, F. David},
  title     = {The Role of Language in Science},
  year      = {2002},
  url       = {https://www.fdavidpeat.com/bibliography/essays/lang.htm},
  % No DOI available -- essay published on author's website
  note      = {Self-published essay; not peer-reviewed.},
  abstract  = {Peat extends David Bohm's framing of language and thought, proposing that grammar be understood as "the set of strategies used for intercommunication" rather than a fixed formal apparatus. Drawing on Bohm's rheomode and the implicate order, Peat asks whether the implicate-explicate structure could model linguistic structure itself — whether language enfolds and unfolds meaning in a way homologous to how Bohm conceived physical reality. The essay explores how Indo-European grammatical categories (noun-verb substance-process divisions) bias scientific thought toward a thing-based ontology, and whether alternative grammars could disclose process-based descriptions.},
  annotation  = {For HUMMBL, Peat's essay is relevant to the DE (decomposition) and SY (synthesis) transformations: the grammar of a reasoning system is not neutral scaffolding but an active strategy of intercommunication that constrains what transformations are expressible. The implicate-order analogy informs Base120's design as a system where possibilities are enfolded and made explicit through cognitive operations rather than stored as static tokens.},
  keywords  = {Bohm, implicate order, grammar, language, science, process ontology, HUMMBL:DE, HUMMBL:SY, HUMMBL:IN, HUMMBL:CO}
}

@online{Priest2015LinguisticConstruction,
  author    = {Priest, Graham},
  title     = {The Linguistic Construction of Reality},
  year      = {2015},
  url       = {https://grahampriest.net/?ddownload=850},
  % No DOI available -- lecture/paper published on author's website
  note      = {Self-published; not peer-reviewed.},
  abstract  = {Priest engages the view — common in continental philosophy, textualism, and certain forms of idealism — that "reality is constructed, in some sense, by language; or as it is sometimes put, by grammar, discourse, or the text." Rather than dismissing this as relativism, Priest takes it seriously as a metaphysical thesis and examines what could make it true. He distinguishes several senses of "construction": causal, constitutive, and semantic, arguing that the strongest defensible version is constitutive — that the structure of reality as we can cognize it is partly constituted by the conceptual-grammatical resources we bring to it. He connects this to Buddhist philosophy, Hegelian idealism, and contemporary metaphysics.},
  annotation  = {For HUMMBL, Priest's analysis is directly relevant to the P (projection) and IN (internalization) transformations: every reasoning system projects a grammatical framework onto its input, and the "reality" it reasons about is co-constituted by that projection. This is not a defect to be eliminated but a condition of cognition that Base120 must make explicit and governable rather than leave implicit.},
  keywords  = {linguistic construction, idealism, metaphysics, textualism, Buddhism, grammar, HUMMBL:P, HUMMBL:IN, HUMMBL:DE, HUMMBL:RE}
}

@book{Weaver1953EthicsRhetoric,
  author    = {Weaver, Richard M.},
  title     = {The Ethics of Rhetoric},
  year      = {1953},
  publisher = {Regnery},
  address   = {Chicago},
  isbn      = {978-0935792337},
  note      = {Reprinted 1985, ISI Press},
  % No DOI available -- original monograph; DOI not registered
  abstract  = {Weaver's The Ethics of Rhetoric argues that rhetoric is not mere persuasion but a morally charged activity whose ethical quality depends on the ontological adequacy of its language. The chapter "Some Rhetorical Aspects of Grammatical Categories" develops the thesis that grammar is not an arbitrary surface convention but discloses structures of being: the grammatical categories of being, becoming, and relation reflect how reality is intelligibly organized. Weaver argues that language must connect to the "intelligential world" — the world as graspable by intellect — and that grammatical form carries epistemic and ethical commitments. Nouns reify, verbs processuate, and the choice of grammatical frame is already a philosophical position.},
  annotation  = {For HUMMBL, Weaver's argument grounds the claim that the Base120 representational grammar is not a neutral encoding but an ontological commitment: the CO (composition) and RE (reasoning) transformations inherit ethical stakes from the grammatical categories they deploy. A reasoning system's grammar is always already an ethics of rhetoric.},
  keywords  = {rhetoric, ethics, grammar, ontology, being, becoming, relation, HUMMBL:CO, HUMMBL:RE, HUMMBL:DE, HUMMBL:SY}
}

