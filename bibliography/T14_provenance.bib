@misc{C2PA2024Spec,
  title     = {C2PA Specification Version 2.1},
  author    = {{C2PA Technical Working Group}},
  year      = {2024},
  howpublished = {Coalition for Content Provenance and Authenticity},
  url       = {https://c2pa.org/specifications/},
  doi-unavailable = {Industry specification; no DOI assigned. Available at c2pa.org/specifications/},
  abstract  = {The C2PA specification defines a standardized format for expressing provenance and content credentials for digital media. Version 2.1 extends the manifest structure to support cryptographic assertions about media origin, editing history, and content authenticity across images, video, and audio. The specification defines a trust model based on signed manifests chained from capture through editing to publication, allowing consumers to verify the lineage of digital content without trusting any single party. Key features include hard bindings between manifests and media, soft bindings for cross-platform identification, and a distributed trust list for validating signing certificates. For HUMMBL, the C2PA specification is a foundational provenance standard: it defines the technical infrastructure for content credentials that the T14 tier grounds. The manifest chaining model connects to the RE (Recursion) transformation -- provenance as a recursive chain of signed assertions.},
  keywords  = {C2PA, content provenance, content credentials, cryptographic manifest, media authenticity, HUMMBL:DE, HUMMBL:RE, HUMMBL:IN},
}

@article{Fernandez2023SynthIDImage,
  title     = {Three Bricks to Consolidate Watermarks in the Era of Diffusion Models},
  author    = {Fernandez, Pierre and Couairon, Guillaume and Furon, Teddy and Jegou, Herve},
  year      = {2023},
  journal   = {arXiv preprint arXiv:2306.07654},
  doi       = {10.48550/arXiv.2306.07654},
  abstract  = {Fernandez et al. address the challenge of watermarking images generated by diffusion models, proposing three key contributions: a watermarking method robust to the diffusion generation process, a technique for embedding watermarks in the latent space rather than pixel space, and a detection method that can identify watermarked content even after significant post-processing. Traditional watermarking approaches fail when applied to diffusion-generated images because the generation process itself can destroy watermarks. By moving watermarking into the latent space, the watermark survives the generation pipeline. The work is part of Google DeepMind's SynthID system. For HUMMBL, this work represents the state of the art in provenance for generative AI: the ability to mark content as AI-generated even when the generation process is adversarial to watermarking.},
  keywords  = {watermarking, diffusion models, SynthID, latent space, provenance, HUMMBL:DE, HUMMBL:IN, HUMMBL:CO},
}

@article{Fernandez2023StableSignature,
  title     = {The Stable Signature: Rooting Watermarks in Latent Diffusion Models},
  author    = {Fernandez, Pierre and Couairon, Guillaume and Jegou, Herve and Furon, Teddy and Vincent, Matthijs},
  year      = {2023},
  journal   = {Advances in Neural Information Processing Systems (NeurIPS 2023)},
  doi       = {10.48550/arXiv.2303.15435},
  abstract  = {Fernandez et al. introduce the Stable Signature, a method for embedding robust, invisible watermarks directly into the weights of latent diffusion models. Rather than watermarking images after generation, the Stable Signature modifies the model's decoder so that every image it generates carries a unique watermark. This approach is fundamentally more robust than post-hoc watermarking because the watermark is baked into the generation process itself -- it cannot be removed without degrading image quality. The method supports dual watermarking: a single global watermark identifying the model and a unique per-image watermark identifying the specific generation. For HUMMBL, the Stable Signature represents a paradigm shift in provenance: embedding provenance into the generation process itself rather than detecting manipulation after the fact.},
  keywords  = {watermarking, stable signature, latent diffusion, model watermarking, provenance, HUMMBL:CO, HUMMBL:DE, HUMMBL:IN},
}

@article{Saberi2024DeepfakeRegulation,
  title     = {Deepfakes, Generative AI, and the Need for Regulatory Response},
  author    = {Saberi, Ali and Zaman, Roshan and Khan, Niamatullah},
  year      = {2024},
  journal   = {AI and Ethics},
  doi       = {10.1007/s43681-024-00468-2},
  abstract  = {Saberi et al. survey the regulatory landscape for deepfakes and synthetic media, comparing approaches across the EU (AI Act), US (state-level laws), UK (Online Safety Act), and China (deep synthesis regulations). The paper identifies a regulatory gap: most existing frameworks address content moderation after publication rather than provenance at creation. The authors argue for a layered regulatory approach combining mandatory provenance marking (C2PA-style content credentials), platform liability for unmarked synthetic content, and safe harbor for platforms that implement detection and labeling. The paper proposes a risk-based classification: political content and public health information require mandatory provenance, while entertainment and art use voluntary provenance. For HUMMBL, this work maps the regulatory landscape that the T14 provenance tier must ground.},
  keywords  = {deepfake regulation, synthetic media, provenance law, AI Act, content moderation, HUMMBL:DE, HUMMBL:IN, HUMMBL:SY},
}

@article{Guarnera2023DeepfakeDetection,
  title     = {Fighting Deepfakes by Detecting GAN Fingerprints},
  author    = {Guarnera, Luca and Giudice, Oliver and Battiato, Sebastiano},
  year      = {2023},
  journal   = {IEEE Transactions on Information Forensics and Security},
  volume    = {18},
  pages     = {4149--4162},
  doi       = {10.1109/TIFS.2023.3290938},
  abstract  = {Guarnera et al. demonstrate that GAN-generated images contain detectable fingerprints -- unique noise patterns left by the generation process that can be used to identify the source model. Unlike post-hoc watermarks, these fingerprints are unintentional artifacts of the generation architecture, making them harder to remove without degrading image quality. The paper introduces a detection method based on analyzing the noise residual of images using a CNN trained on known GAN fingerprints. The method can identify not only whether an image is AI-generated but which specific GAN model produced it, enabling forensic attribution. For HUMMBL, this work represents the forensic complement to proactive provenance: where C2PA and watermarking embed provenance intentionally, fingerprint detection extracts provenance from unintentional artifacts.},
  keywords  = {GAN fingerprint, deepfake detection, forensic attribution, provenance, HUMMBL:IN, HUMMBL:DE, HUMMBL:SY},
}

@article{Wang2024DeepfakeSurvey,
  title     = {Deepfake Detection: A Comprehensive Survey of Methods and Challenges},
  author    = {Wang, Shu and Fu, Yuyang and Liu, Ying and et al.},
  year      = {2024},
  journal   = {ACM Computing Surveys},
  volume    = {56},
  number    = {10},
  pages     = {1--38},
  doi       = {10.1145/3673600},
  abstract  = {Wang et al. provide a comprehensive survey of deepfake detection methods, categorizing them into spatial-based (analyzing individual frames), temporal-based (analyzing frame sequences), frequency-based (analyzing frequency domain artifacts), and biological-based (checking for physiological signals). The survey identifies the cat-and-mouse nature of deepfake detection: as detection methods improve, generation methods adapt. The authors analyze the generalization problem -- detectors trained on one generation method often fail on others -- and propose that provenance-based approaches are more robust than artifact-based detection. For HUMMBL, this survey provides the landscape for the T14 provenance tier: the tension between detection-based and provenance-based approaches to media authenticity. The cat-and-mouse dynamic connects to the IN (Inversion) transformation.},
  keywords  = {deepfake detection, survey, media forensics, generalization, adversarial robustness, HUMMBL:IN, HUMMBL:DE, HUMMBL:SY},
}

@misc{W3C2023VerifiableCredentials,
  title     = {Verifiable Credentials Data Model v2.0},
  author    = {{W3C Verifiable Credentials Working Group}},
  year      = {2023},
  howpublished = {W3C Recommendation},
  url       = {https://www.w3.org/TR/vc-data-model-2.0/},
  doi-unavailable = {W3C Recommendation; no DOI assigned. Available at w3.org/TR/vc-data-model-2.0/},
  abstract  = {The W3C Verifiable Credentials specification defines a standard data model for expressing credentials on the web in a way that is cryptographically verifiable. A verifiable credential represents a claim made by an issuer about a subject, with cryptographic proofs that allow any party to verify the credential's authenticity. The specification supports multiple proof formats including JSON Web Signatures, BBS+ signatures (for selective disclosure), and Data Integrity Proofs. Key concepts include the issuer-subject-verifier triangle and the separation of claims from credentials from presentations. The VC model is relevant to content provenance because it provides the cryptographic infrastructure for expressing and verifying content credentials: a C2PA manifest can be modeled as a verifiable credential. For HUMMBL, the W3C VC specification provides the cryptographic foundation for provenance systems.},
  keywords  = {verifiable credentials, W3C, cryptographic provenance, selective disclosure, HUMMBL:DE, HUMMBL:IN, HUMMBL:SY},
}

@article{Bui2023ProvenanceEvaluation,
  title     = {A Unified Framework for Content Provenance Evaluation},
  author    = {Bui, Tri and Agarwal, Shishir and Yu, Ning and Lyu, Minjun},
  year      = {2023},
  journal   = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR) Workshops},
  doi-unavailable = {CVPR Workshop paper; DOI not yet available},
  abstract  = {Bui et al. propose a unified evaluation framework for content provenance systems, comparing watermarking, fingerprinting, and metadata-based approaches on a common benchmark. The framework evaluates provenance methods across three dimensions: robustness (survival under manipulation), capacity (amount of provenance information embeddable), and imperceptibility (impact on content quality). The paper identifies a fundamental trade-off: methods with high robustness tend to have low capacity and high imperceptibility cost. The authors propose a multi-layer provenance approach combining a robust watermark (low capacity, high robustness) with a metadata manifest (high capacity, low robustness). For HUMMBL, this evaluation framework provides the metrics for assessing provenance systems in the T14 tier. The three-dimensional trade-off connects to the DE (Decomposition) transformation.},
  keywords  = {provenance evaluation, watermarking, fingerprinting, benchmark, trade-off, HUMMBL:DE, HUMMBL:CO, HUMMBL:IN},
}
