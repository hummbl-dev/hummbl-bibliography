@article{Chesney2019DeepFakes,
  title = {Deep Fakes: A Looming Challenge for Privacy, Democracy, and National Security},
  author = {Chesney, Robert and Citron, Danielle Keats},
  year = {2019},
  journal = {California Law Review},
  volume = {107},
  pages = {1753},
  url = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=3213954},
  abstract = {Seminal legal-academic analysis of deepfake technology's harms and the ``Liar's Dividend'' -- the phenomenon where awareness of deepfakes lets wrongdoers dismiss authentic evidence as fake. Surveys technological, criminal, civil, regulatory, and military responses. The Liar's Dividend concept is foundational for understanding why provenance infrastructure is necessary but not sufficient: even with C2PA-style credentials, the erosion of shared epistemic ground creates systemic risk.},
  keywords = {deepfakes, provenance, liar's dividend, regulation, HUMMBL:IN, HUMMBL:DE, HUMMBL:SY},
  nist_functions = {GOVERN MAP},
  doi       = {10.2139/ssrn.3213954},
}

@inproceedings{Kirchenbauer2023Watermark,
  title = {A Watermark for Large Language Models},
  author = {Kirchenbauer, John and Geiping, Jonas and Wen, Yuxin and Katz, Jonathan and Miers, Ian and Goldstein, Tom},
  year = {2023},
  booktitle = {Proceedings of the 40th International Conference on Machine Learning (ICML)},
  series = {PMLR},
  volume = {202},
  pages = {17061--17084},
  url = {https://arxiv.org/abs/2301.10226},
  abstract = {Foundational LLM watermarking paper introducing the ``green-list token'' soft-promotion scheme with interpretable p-value detection, negligible quality impact, and no need for model API access. ICML 2023 Outstanding Paper. The scheme works by slightly biasing the model's next-token distribution toward a set of ``green'' tokens determined by a cryptographic hash of the preceding context. Detection requires only a small sample of text and the hash function -- no model access needed. This is the most widely cited LLM watermarking approach and the basis for much subsequent work on AI content provenance.},
  keywords = {watermarking, LLM, provenance, detection, HUMMBL:DE, HUMMBL:IN, HUMMBL:RE},
  nist_functions = {MEASURE MANAGE},
  doi       = {10.48550/arXiv.2301.10226},
}

@inproceedings{Kirchenbauer2024Reliability,
  title = {On the Reliability of Watermarks for Large Language Models},
  author = {Kirchenbauer, John and Geiping, Jonas and Wen, Yuxin and Shu, Manli and Saifullah, Khalid and Kong, Tom and Fernando, Naren and Saha, Aniruddha and Goldblum, Micah and Goldstein, Tom},
  year = {2024},
  booktitle = {International Conference on Learning Representations (ICLR)},
  url = {https://arxiv.org/abs/2306.04634},
  abstract = {Deep-dive into robustness properties of LLM watermarks under paraphrasing, translation, and adversarial attack. Provides recommended hyperparameter settings for practitioners. Shows that watermark detection remains reliable under moderate perturbation but degrades under aggressive paraphrasing, establishing the practical limits of watermark-based provenance.},
  keywords = {watermarking, LLM, robustness, adversarial, HUMMBL:DE, HUMMBL:IN},
  nist_functions = {MEASURE},
  doi       = {10.48550/arXiv.2306.04634},
}

@article{Dathathri2024SynthID,
  title = {Scalable Watermarking for Identifying Large Language Model Outputs},
  author = {Dathathri, Sumanth and others},
  year = {2024},
  journal = {Nature},
  url = {https://www.nature.com/articles/s41586-024-08025-4},
  abstract = {Production-ready SynthID-Text watermarking scheme preserving text quality with minimal latency. Integrates with speculative sampling for scale. Validated on approximately 20 million Gemini responses showing no user-perceived quality degradation. This is the first production-scale LLM watermarking deployment, demonstrating that watermarking can work at internet scale without degrading user experience. The text watermarking component was open-sourced in October 2024.},
  keywords = {SynthID, watermarking, LLM, production, Google DeepMind, HUMMBL:DE, HUMMBL:IN, HUMMBL:RE},
  nist_functions = {MEASURE MANAGE},
