  author = {{Various}},
  year = {2024},
  url = {https://arxiv.org/html/2401.04364v4},
  abstract = {Systematizes 51 top deepfake detectors (2019--2023) into a unified framework with 18 efficacy factors. Evaluates generalizability of 16 leading detectors across black-box, gray-box, and white-box attack scenarios. Finds that most detectors perform well in-domain but degrade significantly on cross-dataset evaluations, highlighting the generalization gap in deepfake detection.},
  keywords = {deepfake, detection, systematization, benchmark, HUMMBL:DE, HUMMBL:IN},
  nist_functions = {MEASURE},
}

