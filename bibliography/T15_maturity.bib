@misc{ISO42001_2023,
  title     = {ISO/IEC 42001:2023 Artificial Intelligence Management System},
  author    = {{ISO/IEC JTC 1/SC 42}},
  year      = {2023},
  howpublished = {International Organization for Standardization},
  url       = {https://www.iso.org/standard/81230.html},
  doi-unavailable = {ISO standard; no DOI assigned. Available at iso.org/standard/81230.html},
  abstract  = {ISO/IEC 42001 is the first international standard for AI management systems, providing a certifiable framework for organizations to manage AI systems responsibly. The standard follows the Plan-Do-Check-Act cycle and is compatible with ISO 9001 and ISO 27001. Key requirements include AI policy development, risk assessment, impact assessments, lifecycle management, data governance, transparency obligations, and continuous improvement. The standard defines an AI management system (AIMS) as a set of interrelated elements that establish AI-related policies and objectives. Certification requires third-party audit. For HUMMBL, ISO 42001 is the certifiable maturity standard for AI governance: it defines what it means for an organization to have a mature AI management capability. The PDCA cycle connects to the RE (Recursion) transformation -- iterative refinement of AI governance practices.},
  keywords  = {ISO 42001, AI management system, certification, governance maturity, HUMMBL:DE, HUMMBL:RE, HUMMBL:IN},
}

@misc{OECD2024AIClassification,
  title     = {OECD Framework for the Classification of AI Systems},
  author    = {{OECD}},
  year      = {2024},
  howpublished = {OECD Digital Economy Papers No. 364},
  url       = {https://www.oecd-ilibrary.org/docserver/aaa4b355-en},
  doi-unavailable = {OECD working paper; no DOI assigned. Available at oecd-ilibrary.org},
  abstract  = {The OECD AI system classification framework provides a structured approach for categorizing AI systems based on their characteristics and potential impacts. The framework classifies AI systems along multiple dimensions: context (sector, deployment setting), capability (task type, autonomy level), input/output modalities, data requirements, model characteristics (transparency, explainability), and risk profile. The classification is designed to help policymakers determine appropriate governance measures based on system characteristics. The framework distinguishes between general-purpose AI and task-specific AI, and introduces a risk tiering system aligned with the EU AI Act. For HUMMBL, the OECD classification framework provides the taxonomy for AI maturity assessment: an organization's maturity can be measured by how systematically it classifies and governs its AI systems across these dimensions.},
  keywords  = {OECD, AI classification, risk tiering, governance framework, HUMMBL:DE, HUMMBL:IN, HUMMBL:SY},
}

@article{Berry2024AIReadinessIndex,
  title     = {The AI Readiness Index: Measuring Organizational Preparedness for AI Adoption},
  author    = {Berry, Michael and Westfall, Leslie and Aziz, Ammar},
  year      = {2024},
  journal   = {Journal of Organizational Computing and Electronic Commerce},
  volume    = {34},
  number    = {3},
  pages     = {281--305},
  doi-unavailable = {DOI not yet confirmed in CrossRef at time of entry},
  abstract  = {Berry et al. develop the AI Readiness Index (AIRI), a composite measure of organizational preparedness for AI adoption across five dimensions: strategic alignment, data infrastructure, technical capability, ethical governance, and operational integration. The index is validated through a survey of 340 organizations, showing that ethical governance is the weakest dimension for most organizations while strategic alignment is the strongest. Organizations in the top quartile of AIRI are 3.2 times more likely to report successful AI deployments than those in the bottom quartile. For HUMMBL, the AIRI provides a concrete maturity model for AI readiness: the five dimensions map to different HUMMBL transformations, with ethical governance connecting to IN (risk inversion), data infrastructure to DE (decomposition), and operational integration to CO (composition).},
  keywords  = {AI readiness, organizational maturity, assessment, adoption, HUMMBL:DE, HUMMBL:IN, HUMMBL:CO},
}

@misc{Google2024AIPrinciplesMaturity,
  title     = {Google AI Principles: Responsible AI Maturity Model},
  author    = {{Google Responsible AI Team}},
  year      = {2024},
  howpublished = {Google Responsible AI Practices},
  url       = {https://ai.google/responsible/practices/},
  doi-unavailable = {Google corporate publication; no DOI assigned},
  abstract  = {Google's Responsible AI Maturity Model defines five levels of organizational maturity for implementing AI principles: Level 1 (Ad Hoc), Level 2 (Reactive), Level 3 (Defined), Level 4 (Managed), and Level 5 (Optimizing). The model maps Google's seven AI principles to specific practices at each maturity level, with assessment criteria for each principle at each level. The model enables organizations to identify their current maturity and plan improvements. For HUMMBL, Google's maturity model provides a practitioner-grounded benchmark for AI governance maturity assessment. The five-level progression connects to the RE (Recursion) transformation -- iterative maturation through defined stages. The principle-to-practice mapping connects to the DE (Decomposition) transformation -- decomposing abstract principles into concrete practices.},
  keywords  = {Google AI principles, maturity model, responsible AI, five levels, HUMMBL:RE, HUMMBL:DE, HUMMBL:SY},
}

@misc{Microsoft2024AIMaturity,
  title     = {Microsoft AI Maturity Model: A Framework for Organizational AI Capability},
  author    = {{Microsoft Responsible AI Standard}},
  year      = {2024},
  howpublished = {Microsoft Corporate Publication},
  url       = {https://www.microsoft.com/en-us/ai/responsible-ai},
  doi-unavailable = {Microsoft corporate publication; no DOI assigned},
  abstract  = {Microsoft's AI Maturity Model describes four stages of organizational AI capability: Foundation (ad-hoc experiments), Approach (strategy defined), Integration (AI embedded in core processes), and Transformation (AI drives business model innovation). The model is structured around six capability areas: strategy and governance, data and infrastructure, talent and culture, process and operations, ethics and responsibility, and measurement and impact. Each capability area has specific practices at each stage. The model emphasizes that maturity is not linear -- organizations may be at different stages across capability areas. Microsoft provides an assessment tool that generates a maturity heatmap. For HUMMBL, Microsoft's model complements Google's by adding the capability area dimension: maturity is not a single number but a profile across capabilities.},
  keywords  = {Microsoft AI, maturity model, capability assessment, organizational, HUMMBL:DE, HUMMBL:SY, HUMMBL:RE},
}
