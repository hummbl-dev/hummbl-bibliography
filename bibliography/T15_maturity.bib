@techreport{Vorvoreanu2023RAIMaturity,
  title = {Towards a Responsible AI Organizational Maturity Model},
  author = {Vorvoreanu, Mihaela and Heger, Amy and Passi, Sahil and Dhanorkar, Saurabh and Kahn, Zahra and Wang, Richard},
  year = {2023},
  institution = {Microsoft Research},
  number = {MSR-TR-2023-26},
  url = {https://www.microsoft.com/en-us/research/publication/responsible-ai-maturity-model/},
  abstract = {The most empirically grounded AI organizational maturity model, derived from interviews and focus groups with 90+ RAI specialists and AI practitioners. Defines 24 dimensions across three categories (Organizational Foundations, Team Approach, RAI Practice), each with five maturity levels (Level 1: Latent to Level 5: Leading). Designed as a workshop tool for strategic planning, not just a paper. This is the most rigorous organizational AI maturity model currently available and directly operationalizes the concept of organizational RAI maturity.},
  keywords = {responsible AI, maturity model, organizational, HUMMBL:DE, HUMMBL:CO, HUMMBL:RE},
  nist_functions = {GOVERN MAP MEASURE MANAGE},
}

@misc{Metaxa2024NISTMM,
  title = {Evolving AI Risk Management: A Maturity Model based on the NIST AI Risk Management Framework},
  author = {{Various}},
  year = {2024},
  howpublished = {arXiv preprint},
  url = {https://arxiv.org/abs/2401.15229},
  abstract = {Develops a scorable maturity questionnaire mapped to the NIST AI RMF's four functions (GOVERN, MAP, MEASURE, MANAGE) and four implementation tiers (Partial, Risk-Informed, Repeatable, Adaptive). Addresses the explicit gap that the AI RMF lacks a maturity model despite NIST having one for cybersecurity and privacy. Provides scoring methodology and aggregation approach for organizational self-assessment.},
  keywords = {NIST AI RMF, maturity model, risk management, HUMMBL:DE, HUMMBL:SY, HUMMBL:RE},
  nist_functions = {GOVERN MAP MEASURE MANAGE},
}

@misc{Phuong2024DangerousCapabilities,
  title = {Evaluating Frontier Models for Dangerous Capabilities},
  author = {Phuong, Mary and Aitchison, Matthew and Catt, Edmund and others},
  year = {2024},
  howpublished = {Google DeepMind},
  url = {https://deepmind.google/research/publications/78150/},
  abstract = {Introduces a programme of ``dangerous capability'' evaluations piloted on Gemini models across five topics: persuasion and deception, cyber-security, self-proliferation, self-reasoning and self-modification, and biological and nuclear risk. Foundational work for the science of dangerous capability evaluation, directly informing Google DeepMind's Frontier Safety Framework Critical Capability Levels. Establishes the methodological template for independent capability assessment.},
  keywords = {frontier AI, dangerous capabilities, evaluation, Google DeepMind, HUMMBL:DE, HUMMBL:IN, HUMMBL:RE},
  nist_functions = {MEASURE MANAGE},
}

@misc{Weidinger2024HolisticSafety,
