  author = {{Various}},
  year = {2024},
  howpublished = {arXiv preprint},
  url = {https://arxiv.org/abs/2401.15229},
  abstract = {Develops a scorable maturity questionnaire mapped to the NIST AI RMF's four functions (GOVERN, MAP, MEASURE, MANAGE) and four implementation tiers (Partial, Risk-Informed, Repeatable, Adaptive). Addresses the explicit gap that the AI RMF lacks a maturity model despite NIST having one for cybersecurity and privacy. Provides scoring methodology and aggregation approach for organizational self-assessment.},
  keywords = {NIST AI RMF, maturity model, risk management, HUMMBL:DE, HUMMBL:SY, HUMMBL:RE},
  nist_functions = {GOVERN MAP MEASURE MANAGE},
}

