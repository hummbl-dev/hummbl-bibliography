@techreport{Paulhus1991CMM,
  title = {Capability Maturity Model for Software (Version 1.0)},
  author = {Paulhus, William and Weber, Charles and Humphrey, Watts},
  year = {1991},
  institution = {Software Engineering Institute, Carnegie Mellon University},
  url = {https://www.sei.cmu.edu/history-of-innovation/transforming-software-quality-assessment/},
  abstract = {The original Capability Maturity Model, published by the SEI in 1991, establishing the five-level maturity structure (Initial, Repeatable, Defined, Managed, Optimizing) that became the template for all subsequent maturity models including CMMI and AI-specific derivatives. Inspired by Crosby's Manufacturing Maturity Model and Deming's quality principles. This is the foundational anchor work for the entire maturity model family.},
  keywords = {CMM, capability maturity, software, SEI, heritage, HUMMBL:RE, HUMMBL:DE, HUMMBL:SY},
}

