% T18_human_oversight.bib — Human Oversight and Human Factors in AI
% Added 2026-06-27 to fill Family 17 gap identified in bibliography cross-reference
%
% These entries cover trust calibration, automation bias, meaningful human control,
% and human-AI teaming for AI oversight.

@article{Wischnewski2023TrustCalibration,
  title = {Measuring and Understanding Trust Calibrations for Automated Systems: A Survey of the State-of-the-Art and Future Directions},
  author = {Wischnewski, Sven and Korber, Christiane},
  year = {2023},
  journal = {Theoretical Issues in Ergonomics Science},
  url = {https://doi.org/10.1080/1463922X.2023.2182681},
  abstract = {Systematic review of 96 publications on trust calibration interventions structuring them into four dimensions (warranted vs. unwarranted, static vs. adaptive, capabilities vs. process-oriented). Identifies measurement limitations that constrain interpretation of calibration effectiveness.},
  keywords = {trust calibration, automation, survey, HUMMBL:P, HUMMBL:IN},
  nist_functions = {GOVERN MEASURE},
  doi       = {10.1145/3544548.3581197},
}

@article{AlonBarkat2024EffectiveOversight,
  title = {Effective Human Oversight of AI-Based Systems: A Signal Detection Perspective on the Detection of Inaccurate and Unfair Outputs},
  author = {Alon-Barkat, Saar and Busuioc, M. Amos},
  year = {2025},
  journal = {Journal of Public Administration Research and Theory},
  url = {https://academic.oup.com/jpart},
  abstract = {Proposes Signal Detection Theory as a framework for understanding human error detection in AI oversight. Analyzes sensitivity and response bias factors that affect detection of both inaccurate and unfair AI outputs. Directly relevant to EU AI Act Art. 14 effectiveness requirements.},
  keywords = {human oversight, signal detection, fairness, HUMMBL:P, HUMMBL:DE},
  nist_functions = {MEASURE MANAGE},
}

@article{Busuioc2025AutomationBiasAIA,
  title = {Automation Bias in the AI Act: On the Legal Implications of Attempting to De-Bias Human Oversight of AI},
  author = {Busuioc, M. Amos and Alon-Barkat, Saar},
  year = {2025},
  journal = {Law, Innovation and Technology},
  url = {https://www.tandfonline.com/journals/rlit20},
  abstract = {Analyzes the legal implications of automation bias being explicitly mentioned in the AI Act. Examines the asymmetric responsibility division between providers and deployers and argues that harmonized standards should reference behavioral science research on human-AI interaction.},
  keywords = {automation bias, EU AI Act, legal, HUMMBL:P, HUMMBL:DE},
  nist_functions = {GOVERN MANAGE},
}

@article{deKoning2023ManyMeaningsMHC,
  title = {The Many Meanings of Meaningful Human Control},
  author = {de Koning, Pim and van der Waa, Jeroen and van den Hoven, Jeroen and others},
  year = {2024},
  journal = {Philosophy \& Technology},
  url = {https://link.springer.com/article/10.1007/s13347-023-00655-7},
  abstract = {Deconstructs "meaningful human control" into its constituent concepts (meaningful, human, control) identifying multiple interpretations across designer, operator, subject, and government roles. Relevant for translating MHC from ethical concept to design requirements.},
  keywords = {meaningful human control, ethics, HUMMBL:P, HUMMBL:SY},
  nist_functions = {GOVERN MAP},
}

@inproceedings{vanDerWaa2023ActionableMHC,
  title = {Meaningful Human Control: Actionable Properties for AI System Development},
  author = {van der Waa, Jeroen and Verdiesen, Jurriaan and van Diggelen, Jeroen and van den Hoven, Jeroen},
  year = {2023},
  booktitle = {Proceedings of the 2023 AAAI/ACM Conference on AI, Ethics, and Society},
  url = {https://dl.acm.org/doi/10.1145/3600211.3604676},
  abstract = {Bridges philosophical theory and engineering practice by identifying four actionable properties for AI systems under meaningful human control. Provides concrete requirements for designers to maintain human control over autonomous AI systems.},
  keywords = {meaningful human control, actionable, design, HUMMBL:P, HUMMBL:DE},
  nist_functions = {MAP MEASURE},
  doi       = {10.1007/s43681-022-00167-3},
}

@article{Carey2023HumanControl,
  title = {Human Control: Definitions and Algorithms},
  author = {Carey, Ryan and Everitt, Tom and Sherburne, Luke and others},
  year = {2023},
  journal = {arXiv preprint},
  url = {https://arxiv.org/abs/2310.07778},
  abstract = {Formally defines "shutdown instructability" as a variant of corrigibility showing it implies appropriate shutdown behavior, retention of human autonomy, and avoidance of user harm. Analyzes related concepts (non-obstruction, shutdown alignment) and proposes algorithms for human control of advanced AI.},
  keywords = {human control, corrigibility, shutdown, HUMMBL:P, HUMMBL:SY},
  nist_functions = {MAP MANAGE},
}

@article{Yang2023TrustDynamics,
  title = {Toward Quantifying Trust Dynamics: How People Adjust Their Trust After Moment-to-Moment Interaction With Automation},
  author = {Yang, X. Jessie and Wafa, Sarah Al and Unni, Aakash and Itoh, Makoto},
  year = {2023},
  journal = {Human Factors},
  url = {https://journals.sagepub.com/doi/10.1177/00187208231187258},
  abstract = {First experimental study examining how outcome bias and contrast effect influence moment-to-moment trust adjustments in human-automation interaction. Finds automation failures have larger effects on trust than successes, with implications for oversight reliability.},
  keywords = {trust dynamics, automation, experimental, HUMMBL:P, HUMMBL:IN},
  nist_functions = {MEASURE},
  doi       = {10.1177/00187208211034716},
}

@article{Vogel2025AutomationBiasReview,
  title = {Exploring Automation Bias in Human-AI Collaboration: A Review and Implications for Explainable AI},
  author = {Vogel, Tobias and K{\"o}ppen, Eva and others},
  year = {2025},
  journal = {Computers in Human Behavior},
  url = {https://www.sciencedirect.com/journal/computers-in-human-behavior},
  abstract = {PRISMA-guided systematic review of 35 studies (2015-2025) on automation bias in modern AI-driven work environments. Finds that XAI explanations may inadvertently reinforce misplaced trust, especially among less experienced professionals, and identifies user engagement as the most impactful intervention point.},
  keywords = {automation bias, XAI, systematic review, HUMMBL:P, HUMMBL:IN},
  nist_functions = {MEASURE MANAGE},
}

@inproceedings{Bucinca2023DecisionControl,
  title = {Decision Control and Explanations in Human-AI Collaboration: Improving User Perceptions and Compliance},
  author = {Bucinca, Zana and Malaya, Maja and Gajos, Krzysztof Z.},
  year = {2023},
  booktitle = {Proceedings of the 2023 CHI Conference on Human Factors in Computing Systems},
  url = {https://arxiv.org/abs/2303.03578},
  abstract = {Three experimental studies showing that granting users decision control (ability to adjust AI recommendations) improves trust and compliance, while explanations can increase task complexity and harm outcomes unless designed for the user's cognitive ability. Integrates cognitive load theory into human-AI interaction.},
  keywords = {decision control, explanations, cognitive load, HUMMBL:P, HUMMBL:IN},
  nist_functions = {MAP MEASURE},
}

@article{Schlicker2024AutomationBiasPublicAdmin,
  title = {Automation Bias in Public Administration: An Interdisciplinary Perspective from Law and Psychology},
  author = {Schlicker, Fabian and others},
  year = {2024},
  journal = {Law, Innovation and Technology},
  url = {https://www.tandfonline.com/journals/rlit20},
  abstract = {Interdisciplinary analysis of automation bias in public sector AI decision-making examining the inadequacies of EU legal frameworks in addressing automation bias risks. Proposes four steps for countering automation bias perils, linking psychological insights with legal analysis.},
  keywords = {automation bias, public administration, law, HUMMBL:P, HUMMBL:DE},
  nist_functions = {GOVERN MANAGE},
}
